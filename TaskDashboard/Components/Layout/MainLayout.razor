@inherits LayoutComponentBase
@inject DashboardService Dashboard
@inject IJSRuntime JS

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Apply the persisted theme preference as soon as the app opens.
            await Dashboard.LoadAsync();
            await JS.InvokeVoidAsync("taskDashboard.applyTheme", Dashboard.Theme);
        }
    }
}
