@* Add/edit dialog shared by both flows. The parent renders this component
   conditionally, so mounting it means "open". Esc or a backdrop click cancels. *@

<div class="modal-backdrop-area" @onclick="() => OnCancel.InvokeAsync()">
    <div class="modal-panel"
         role="dialog"
         aria-modal="true"
         aria-labelledby="task-modal-title"
         @onclick:stopPropagation
         @onkeydown="HandleKeyAsync">
        <h2 id="task-modal-title">@Title</h2>

        <EditForm Model="Form" OnValidSubmit="() => OnSave.InvokeAsync()">
            <DataAnnotationsValidator />

            <TaskFields @ref="fields" Form="Form" />

            <ValidationSummary />

            <div class="modal-actions">
                <button type="submit" class="btn btn-primary">Save</button>
                <button type="button" class="btn btn-outline-secondary" @onclick="() => OnCancel.InvokeAsync()">
                    Cancel
                </button>
            </div>

            @if (ShowSplit)
            {
                <div class="split-row">
                    <label for="split-parts">Split into</label>
                    <select id="split-parts" class="form-select form-select-sm split-select" @bind="splitParts">
                        <option value="2">2 parts</option>
                        <option value="3">3 parts</option>
                        <option value="4">4 parts</option>
                    </select>
                    <button type="button" class="btn btn-sm btn-outline-primary btn-split"
                            @onclick="() => OnSplit.InvokeAsync(splitParts)">
                        Split task
                    </button>
                </div>
                <small class="split-hint">Divides the estimate into independent part-tasks the planner schedules separately.</small>
            }
        </EditForm>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public TaskForm Form { get; set; } = default!;

    [Parameter]
    public bool ShowSplit { get; set; }

    [Parameter]
    public EventCallback<int> OnSplit { get; set; }

    [Parameter]
    public EventCallback OnSave { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private int splitParts = 2;

    private TaskFields? fields;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && fields is not null)
        {
            await fields.FocusTitleAsync();
        }
    }

    private Task HandleKeyAsync(KeyboardEventArgs e) =>
        e.Key == "Escape" ? OnCancel.InvokeAsync() : Task.CompletedTask;
}
