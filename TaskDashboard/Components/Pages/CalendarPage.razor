@page "/calendar"
@inject DashboardService Todos
@inject IJSRuntime JS
@implements IDisposable

<h1>Calendar</h1>
<p class="cal-subtitle">@WeekRangeText</p>

<div class="cal-toolbar">
    <div class="btn-group" role="group" aria-label="Week navigation">
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => ShiftWeek(-1)">‹ Previous week</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="GoToday" disabled="@IsCurrentWeek">Today</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => ShiftWeek(1)">Next week ›</button>
    </div>
</div>

@{ var week = BuildWeek(); }

<div class="cal-scroll" @ref="scrollArea">
    <div class="cal-header">
        <div class="cal-gutter-spacer"></div>
        @foreach (var day in week.Days)
        {
            <div class="cal-head-day @(day.IsToday ? "today" : null) @(day.IsWeekend ? "weekend" : null)">
                @day.Date.ToString("ddd d MMM")
            </div>
        }
    </div>

    <div class="cal-grid">
        <div class="cal-gutter">
            @for (var h = 0; h < 24; h++)
            {
                <div class="cal-hour-label" style="top:@(h * HourPx)px">@($"{h:00}:00")</div>
            }
        </div>

        @foreach (var day in week.Days)
        {
            <div class="cal-day @(day.IsToday ? "today" : null) @(day.IsWeekend ? "weekend" : null)">
                @foreach (var block in day.Blocks)
                {
                    <div class="@block.Css"
                         style="top:@(block.Top)px;height:@(block.Height)px"
                         title="@block.Tooltip">
                        <span class="cal-block-time">@block.TimeText</span>
                        <span class="cal-block-title">@block.Title</span>
                    </div>
                }

                @foreach (var marker in day.Markers)
                {
                    <div class="cal-deadline" style="top:@(marker.Top)px" title="@marker.Tooltip">
                        <span class="cal-deadline-chip">@marker.Title</span>
                    </div>
                }

                @if (day.IsToday)
                {
                    <div class="cal-now-line" style="top:@(NowOffsetPx)px" data-time="@DateTime.Now.ToString("HH:mm")"></div>
                }
            </div>
        }
    </div>

    @if (week.Empty)
    {
        <div class="cal-empty">Nothing scheduled this week</div>
    }
</div>

@code {
    private const double HourPx = 48;
    private static readonly TimeSpan PlanHorizon = TimeSpan.FromDays(14);

    private DateTime weekStart;
    private ElementReference scrollArea;
    private readonly PeriodicTimer clock = new(TimeSpan.FromSeconds(60));

    private static DateTime Today => DateTime.Today;

    private static double NowOffsetPx => DateTime.Now.TimeOfDay.TotalHours * HourPx;

    private bool IsCurrentWeek => weekStart == StartOfWeek(Today);

    private string WeekRangeText =>
        $"{weekStart:d MMM} – {weekStart.AddDays(6):d MMM yyyy}";

    private sealed record Block(double Top, double Height, string Css, string TimeText, string Title, string Tooltip);
    private sealed record Marker(double Top, string Title, string Tooltip);
    private sealed record DayView(DateTime Date, bool IsToday, bool IsWeekend, List<Block> Blocks, List<Marker> Markers);
    private sealed record WeekView(List<DayView> Days, bool Empty);

    protected override async Task OnInitializedAsync()
    {
        weekStart = StartOfWeek(Today);
        await Todos.LoadAsync();
        Todos.Changed += OnDataChanged;
        _ = TickAsync();
    }

    private void OnDataChanged() => _ = InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Drop the viewport at 07:00 so the working day is in view.
            await JS.InvokeVoidAsync("taskDashboard.scrollTo", scrollArea, 7 * HourPx);
        }
    }

    private async Task TickAsync()
    {
        try
        {
            while (await clock.WaitForNextTickAsync())
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // Component disposed.
        }
    }

    public void Dispose()
    {
        Todos.Changed -= OnDataChanged;
        clock.Dispose();
    }

    private static DateTime StartOfWeek(DateTime date)
    {
        var diff = ((int)date.DayOfWeek - (int)DayOfWeek.Monday + 7) % 7;
        return date.AddDays(-diff);
    }

    private void ShiftWeek(int direction) => weekStart = weekStart.AddDays(direction * 7);

    private void GoToday() => weekStart = StartOfWeek(Today);

    /// <summary>Computes the whole visible week in one pass: one planner run,
    /// then per-day clipping.</summary>
    private WeekView BuildWeek()
    {
        var now = DateTimeOffset.Now;
        var busy = BlockedTime.Expand(Todos.BlockedPeriods, now, now + PlanHorizon);
        var plan = Planner.Plan(Todos.Items, busy, now, PlanHorizon, Todos.BreakBetweenTasks);

        var days = new List<DayView>(7);
        for (var d = 0; d < 7; d++)
        {
            var date = weekStart.AddDays(d);
            days.Add(new DayView(
                date,
                date == Today,
                date.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday,
                BlocksFor(date, plan),
                DeadlinesFor(date)));
        }

        var empty = days.All(day => day.Blocks.Count == 0 && day.Markers.Count == 0);
        return new WeekView(days, empty);
    }

    private List<Block> BlocksFor(DateTime day, List<PlannedSlot> plan)
    {
        var dayStart = new DateTimeOffset(day, DateTimeOffset.Now.Offset);
        var dayEnd = dayStart.AddDays(1);
        var blocks = new List<Block>();

        // Blocked time shades the background of the column.
        foreach (var (period, range) in BlockedTime.ExpandDetailed(Todos.BlockedPeriods, dayStart, dayEnd))
        {
            var (top, height) = Clip(range.Start, range.End, dayStart, dayEnd);
            blocks.Add(new Block(
                top, height, "cal-block cal-blocked",
                range.Start.ToLocalTime().ToString("HH:mm"),
                period.Label,
                $"Blocked: {period.Label}"));
        }

        // Planned slots for unfinished work, routed around blocked time.
        foreach (var slot in plan)
        {
            if (slot.End <= dayStart || slot.Start >= dayEnd)
            {
                continue;
            }

            var task = Todos.Items.FirstOrDefault(t => t.Id == slot.TaskId);
            if (task is null)
            {
                continue;
            }

            var (top, height) = Clip(slot.Start, slot.End, dayStart, dayEnd);
            var css = $"cal-block cal-slot cal-p-{task.Priority.ToString().ToLowerInvariant()}{(slot.MissesDeadline ? " missed" : "")}{(task.IsInProgress ? " started" : "")}";
            var tooltip = slot.MissesDeadline
                ? $"{task.Title} — planned {slot.Start.ToLocalTime():HH:mm}–{slot.End.ToLocalTime():HH:mm}, finishes after its deadline"
                : $"{task.Title} — planned {slot.Start.ToLocalTime():HH:mm}–{slot.End.ToLocalTime():HH:mm}";
            if (task.IsInProgress)
            {
                tooltip += " (in progress)";
            }

            blocks.Add(new Block(top, height, css, slot.Start.ToLocalTime().ToString("HH:mm"), task.Title, tooltip));
        }

        // What was actually done. When the task was started, [StartedAt,
        // CompletedAt] is the real span; otherwise fall back to painting the
        // estimate backwards from completion.
        foreach (var task in Todos.Items.Where(t => t.IsDone && t.CompletedAt is not null))
        {
            var end = task.CompletedAt!.Value.ToLocalTime();
            var start = task.StartedAt is { } begun && begun < task.CompletedAt
                ? begun.ToLocalTime()
                : end - (task.EstimatedTime ?? Planner.DefaultEstimate);
            if (end <= dayStart || start >= dayEnd)
            {
                continue;
            }

            var (top, height) = Clip(start, end, dayStart, dayEnd);
            blocks.Add(new Block(
                top, height, "cal-block cal-done",
                end.ToString("HH:mm"),
                $"✓ {task.Title}",
                $"{task.Title} — completed {end:HH:mm}"));
        }

        return blocks;
    }

    private List<Marker> DeadlinesFor(DateTime day)
    {
        var dayStart = new DateTimeOffset(day, DateTimeOffset.Now.Offset);
        var dayEnd = dayStart.AddDays(1);
        var markers = new List<Marker>();

        foreach (var task in Todos.Items.Where(t => !t.IsDone && t.Deadline is not null))
        {
            var deadline = task.Deadline!.Value.ToLocalTime();
            if (deadline < dayStart || deadline >= dayEnd)
            {
                continue;
            }

            var top = (deadline - dayStart).TotalHours * HourPx;
            markers.Add(new Marker(top, $"⚑ {task.Title}", $"Deadline: {task.Title}, {deadline:HH:mm}"));
        }

        return markers;
    }

    private static (double Top, double Height) Clip(
        DateTimeOffset start, DateTimeOffset end, DateTimeOffset dayStart, DateTimeOffset dayEnd)
    {
        var visibleStart = start < dayStart ? dayStart : start;
        var visibleEnd = end > dayEnd ? dayEnd : end;
        var top = (visibleStart - dayStart).TotalHours * HourPx;
        var height = Math.Max((visibleEnd - visibleStart).TotalHours * HourPx, 14);
        return (top, height);
    }
}
