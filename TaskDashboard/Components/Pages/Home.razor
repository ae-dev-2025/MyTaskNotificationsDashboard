@page "/tasks"
@inject DashboardService Todos

<h1>Tasks</h1>

<div class="task-toolbar">
    <button type="button" class="btn btn-primary" @onclick="BeginAdd">Add task</button>
</div>

@if (Todos.Items.Count == 0)
{
    <p class="task-empty">Nothing here yet. Add your first task above.</p>
}
else
{
    <div class="task-filters" role="group" aria-label="Filter tasks">
        @foreach (var option in Enum.GetValues<Filter>())
        {
            <button type="button"
                    class="btn btn-sm @(filter == option ? "btn-secondary" : "btn-outline-secondary")"
                    aria-pressed="@(filter == option)"
                    @onclick="() => filter = option">
                @option
            </button>
        }
    </div>

    <ul class="task-list">
        @foreach (var item in Visible)
        {
            <li class="task-item @(item.IsDone ? "done" : null) @(item.IsOverdue(Now) ? "overdue" : null) @(item.IsInProgress ? "started" : null)"
                @key="item.Id">
                <input type="checkbox"
                       class="form-check-input"
                       checked="@item.IsDone"
                       aria-label="@($"Mark \"{item.Title}\" as {(item.IsDone ? "not done" : "done")}")"
                       @onchange="() => Todos.ToggleAsync(item.Id)" />

                <div class="task-body" @ondblclick="() => BeginEdit(item)">
                    <span class="task-title">@item.Title</span>

                    <span class="task-meta">
                        <span class="badge priority priority-@item.Priority.ToString().ToLowerInvariant()">
                            @item.Priority
                        </span>

                        @if (item.IsInProgress)
                        {
                            <span class="badge inprogress">in progress</span>
                        }

                        @if (item.Deadline is { } deadline)
                        {
                            <span class="meta deadline" title="Deadline">
                                @FormatDeadline(deadline)
                                @if (item.IsOverdue(Now))
                                {
                                    <span class="overdue-flag">overdue</span>
                                }
                            </span>
                        }

                        @if (item.EstimatedTime is { } estimate)
                        {
                            <span class="meta estimate" title="Estimated time to complete">
                                ~@FormatDuration(estimate)
                            </span>
                        }
                    </span>
                </div>

                @if (!item.IsDone)
                {
                    @if (item.IsInProgress)
                    {
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary row-stop"
                                aria-label="@($"Stop \"{item.Title}\"")"
                                @onclick="() => Todos.StopAsync(item.Id)">
                            Stop
                        </button>
                    }
                    else
                    {
                        <button type="button"
                                class="btn btn-sm btn-outline-success row-start"
                                aria-label="@($"Start \"{item.Title}\"")"
                                @onclick="() => Todos.StartAsync(item.Id)">
                            Start
                        </button>
                    }
                }

                <button type="button"
                        class="btn btn-sm btn-outline-secondary"
                        aria-label="@($"Edit \"{item.Title}\"")"
                        @onclick="() => BeginEdit(item)">
                    Edit
                </button>

                <button type="button"
                        class="btn btn-sm btn-outline-danger"
                        aria-label="@($"Delete \"{item.Title}\"")"
                        @onclick="() => Todos.DeleteAsync(item.Id)">
                    Delete
                </button>
            </li>
        }
    </ul>

    <div class="task-footer">
        <span>
            @RemainingCount @(RemainingCount == 1 ? "task" : "tasks") left
            @if (RemainingEstimate > TimeSpan.Zero)
            {
                <span class="footer-estimate">· ~@FormatDuration(RemainingEstimate) estimated</span>
            }
        </span>
        @if (Todos.Items.Any(i => i.IsDone))
        {
            <button type="button" class="btn btn-sm btn-link" @onclick="Todos.ClearCompletedAsync">
                Clear completed
            </button>
        }
    </div>
}

@if (modalOpen)
{
    <TaskModal Title="@(editingId is null ? "Add task" : "Edit task")"
               Form="form"
               ShowSplit="CanSplitEditing"
               OnSplit="SplitAsync"
               OnSave="SaveAsync"
               OnCancel="CloseModal" />
}

@code {
    private enum Filter { All, Active, Completed }

    private readonly TaskForm form = new();

    private Filter filter = Filter.All;
    private bool modalOpen;
    private Guid? editingId;

    private static DateTimeOffset Now => DateTimeOffset.Now;

    private int RemainingCount => Todos.Items.Count(i => !i.IsDone);

    private TimeSpan RemainingEstimate => Todos.Items
        .Where(i => !i.IsDone && i.EstimatedTime.HasValue)
        .Aggregate(TimeSpan.Zero, (total, i) => total + i.EstimatedTime!.Value);

    private IEnumerable<TodoItem> Visible => filter switch
    {
        Filter.Active => Todos.Items.Where(i => !i.IsDone),
        Filter.Completed => Todos.Items.Where(i => i.IsDone),
        _ => Todos.Items,
    };

    protected override Task OnInitializedAsync() => Todos.LoadAsync();

    private void BeginAdd()
    {
        form.Reset();
        editingId = null;
        modalOpen = true;
    }

    private void BeginEdit(TodoItem item)
    {
        var source = TaskForm.From(item);
        form.Title = source.Title;
        form.Deadline = source.Deadline;
        form.Priority = source.Priority;
        form.EstimatedMinutes = source.EstimatedMinutes;

        editingId = item.Id;
        modalOpen = true;
    }

    private void CloseModal() => modalOpen = false;

    private async Task SaveAsync()
    {
        if (editingId is { } id)
        {
            await Todos.UpdateAsync(id, form.Title, form.Deadline, form.Priority, form.EstimatedTime, form.NotBefore);
        }
        else
        {
            await Todos.AddAsync(form.Title, form.Deadline, form.Priority, form.EstimatedTime, form.NotBefore);
        }

        modalOpen = false;
    }

    private bool CanSplitEditing =>
        editingId is { } id
        && Todos.Items.FirstOrDefault(i => i.Id == id) is { IsDone: false, IsInProgress: false };

    private async Task SplitAsync(int parts)
    {
        if (editingId is { } id)
        {
            await Todos.SplitAsync(id, parts);
        }

        modalOpen = false;
    }

    private static string FormatDeadline(DateTimeOffset deadline) =>
        deadline.ToLocalTime().ToString("ddd d MMM, HH:mm");

    private static string FormatDuration(TimeSpan duration)
    {
        var hours = (int)duration.TotalHours;
        var minutes = duration.Minutes;

        if (hours > 0)
        {
            return minutes > 0 ? $"{hours}h {minutes}m" : $"{hours}h";
        }

        return $"{minutes}m";
    }
}
