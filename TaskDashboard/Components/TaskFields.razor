@* The four editable task fields with visible labels, shared by the add and
   edit flows via TaskModal. *@

<div class="task-fields">
    <div class="field">
        <label for="task-title">Title</label>
        <InputText id="task-title"
                   @ref="titleInput"
                   @bind-Value="Form.Title"
                   class="form-control"
                   placeholder="What needs doing?" />
    </div>

    <div class="field">
        <label for="task-deadline">Deadline</label>
        <InputDate id="task-deadline"
                   Type="InputDateType.DateTimeLocal"
                   @bind-Value="Form.Deadline"
                   class="form-control" />
    </div>

    <div class="field">
        <label for="task-priority">Priority</label>
        <InputSelect id="task-priority"
                     @bind-Value="Form.Priority"
                     class="form-select">
            @foreach (var priority in Enum.GetValues<TaskPriority>())
            {
                <option value="@priority">@priority</option>
            }
        </InputSelect>
    </div>

    <div class="field">
        <label for="task-estimate">Estimate (mins)</label>
        <InputNumber id="task-estimate"
                     @bind-Value="Form.EstimatedMinutes"
                     class="form-control"
                     placeholder="e.g. 30"
                     min="1" />
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public TaskForm Form { get; set; } = default!;

    private InputText? titleInput;

    /// <summary>Moves focus to the title box. Called by the modal when it opens.</summary>
    public async ValueTask FocusTitleAsync()
    {
        if (titleInput?.Element is { } element)
        {
            await element.FocusAsync();
        }
    }
}
